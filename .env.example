# Phone Bridge — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── AI backend ────────────────────────────────────────────────────────────────
# Default: OpenClaw gateway (Claude Sonnet via local OpenClaw)
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token     # Cursor Settings → openclaw.gatewayToken
OPENCLAW_MODEL=openclaw:friday
# To use Ollama instead (fully offline): set URL=http://localhost:11434, MODEL=llama3.2, TOKEN=ollama

# ── STT / TTS (fully local — no API keys) ────────────────────────────────────
WHISPER_MODEL=tiny.en                         # tiny.en | small.en | medium.en
KOKORO_VOICE=af_heart                         # af_heart | am_echo | af_sarah | am_adam
KOKORO_SPEED=1.0
VOICEBOX_URL=http://localhost:17493           # used as STT fallback only

# ── Android Phone ─────────────────────────────────────────────────────────────
PHONE_IP=192.168.1.XXX                        # set after android-sms-gateway is running
PHONE_PORT=8080

# ── android-sms-gateway credentials ──────────────────────────────────────────
SMS_GATEWAY_USER=admin
SMS_GATEWAY_PASS=change-me

# ── Asterisk SIP secrets ──────────────────────────────────────────────────────
ASTERISK_SIP_SECRET=change-me-strong-password
ASTERISK_MANAGER_SECRET=change-me-strong-password

# ── Linphone SIP credentials ──────────────────────────────────────────────────
SIP_PHONE_USER=android-phone
SIP_PHONE_PASS=change-me-strong-password       # must match ASTERISK_SIP_SECRET

# ── Local server ──────────────────────────────────────────────────────────────
SERVER_PORT=3001
AI_MAX_TOKENS=256
ADB_SERIAL=ZY22K45948  # your phone's ADB serial (run: adb devices)
