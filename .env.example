# Phone Bridge — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# AI / Speech APIs
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Default: Rachel. Find IDs at elevenlabs.io

# Asterisk secrets (used in config/asterisk/sip.conf and manager.conf)
ASTERISK_SIP_SECRET=change-me-strong-password
ASTERISK_MANAGER_SECRET=change-me-strong-password

# Android SMS Gateway
SMS_GATEWAY_URL=http://192.168.1.XXX:8080   # android-sms-gateway app URL on phone
SMS_GATEWAY_USER=admin
SMS_GATEWAY_PASS=change-me

# Optional tuning
AI_MODEL=claude-haiku-4-5
AI_MAX_TOKENS=256
DEEPGRAM_MODEL=nova-2
ELEVENLABS_MODEL=eleven_turbo_v2
