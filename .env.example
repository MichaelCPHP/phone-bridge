# Phone Bridge — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── AI / Speech APIs ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Default: Rachel. Find IDs at elevenlabs.io

# ── Android Phone ─────────────────────────────────────────────────────────────
PHONE_IP=192.168.1.XXX          # Phone's LAN IP — set this when phone is on network
PHONE_PORT=8080                  # android-sms-gateway default port

# ── android-sms-gateway credentials (set in the app) ─────────────────────────
SMS_GATEWAY_USER=admin
SMS_GATEWAY_PASS=change-me

# ── Asterisk SIP secrets ──────────────────────────────────────────────────────
ASTERISK_SIP_SECRET=change-me-strong-password
ASTERISK_MANAGER_SECRET=change-me-strong-password

# ── SIP phone credentials (for Linphone on Android) ──────────────────────────
SIP_PHONE_USER=android-phone
SIP_PHONE_PASS=change-me-strong-password   # must match ASTERISK_SIP_SECRET

# ── Local server ──────────────────────────────────────────────────────────────
SERVER_PORT=3001                 # SMS gateway Flask server port

# ── Optional tuning ───────────────────────────────────────────────────────────
AI_MODEL=claude-haiku-4-5
AI_MAX_TOKENS=256
DEEPGRAM_MODEL=nova-2
ELEVENLABS_MODEL=eleven_turbo_v2
